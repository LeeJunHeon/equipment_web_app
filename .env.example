# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://equipment.vanam.synology.me

# Google OAuth (포털/재고관리와 동일한 값 사용)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PostgreSQL (재고관리 DB와 동일한 값 사용)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=inventory

AUTH_TRUST_HOST=true

# MCP 조회용 머신 토큰 (내부 읽기 엔드포인트 /api/internal/* 인증)
EQUIP_MCP_TOKEN=

# 내부 쓰기 전용 토큰 (포털에서 장비 이력 생성 호출 시. 조회용 EQUIP_MCP_TOKEN과 별개)
# 생성 예: openssl rand -hex 32
EQUIP_WRITE_TOKEN=
