generator client {
  provider        = "prisma-client-js"
  output          = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["equipment"]
}

model Equipment {
  id            Int      @id @default(autoincrement())
  name          String   @db.VarChar(100)
  category      String?  @db.VarChar(100)
  isVentTarget     Boolean  @default(false) @map("is_vent_target")
  isCleaningTarget Boolean  @default(true)  @map("is_cleaning_target")
  description      String?  @db.Text
  isActive             Boolean  @default(true)  @map("is_active")
  ventIntervalDays     Int      @default(30)    @map("vent_interval_days")
  cleaningIntervalDays Int      @default(14)    @map("cleaning_interval_days")
  createdAt            DateTime @default(now()) @map("created_at")

  logs EquipmentLog[]

  @@map("equipments")
  @@schema("equipment")
}

model EquipmentLog {
  id            Int       @id @default(autoincrement())
  equipmentId   Int       @map("equipment_id")
  eventType     String    @db.VarChar(20)  @map("event_type")
  occurredAt    DateTime  @map("occurred_at")
  operator      String    @db.VarChar(50)
  description   String?   @db.Text
  status        String    @default("처리중") @db.VarChar(20)

  symptom       String?   @db.Text
  replacedParts String?   @db.Text        @map("replaced_parts")
  isExternal    Boolean   @default(false)  @map("is_external")
  vendorName    String?   @db.VarChar(100) @map("vendor_name")

  ventReason    String?   @db.VarChar(50)  @map("vent_reason")
  finalPressure String?   @db.VarChar(50)  @map("final_pressure")
  pumpedDownAt  DateTime? @map("pumped_down_at")

  cleaningType      String?   @db.VarChar(50) @map("cleaning_type")
  nextScheduledAt   DateTime? @map("next_scheduled_at") @db.Date

  createdAt     DateTime  @default(now()) @map("created_at")

  equipment Equipment        @relation(fields: [equipmentId], references: [id])
  photos    EquipmentPhoto[]
  entries   EquipmentLogEntry[]

  @@map("equipment_logs")
  @@schema("equipment")
}

model EquipmentPhoto {
  id        Int      @id @default(autoincrement())
  logId     Int?     @map("log_id")
  fileName  String   @db.VarChar(255) @map("file_name")
  mimeType  String   @db.VarChar(50)  @map("mime_type")
  fileData  String   @db.Text         @map("file_data")
  fileSize  Int?     @map("file_size")
  createdAt DateTime @default(now())  @map("created_at")

  log EquipmentLog? @relation(fields: [logId], references: [id], onDelete: Cascade)

  @@map("equipment_photos")
  @@schema("equipment")
}

model EquipmentLogEntry {
  id         Int                   @id @default(autoincrement())
  logId      Int                   @map("log_id")
  memo       String?               @db.Text
  occurredAt DateTime              @default(now()) @map("occurred_at")
  createdAt  DateTime              @default(now()) @map("created_at")
  log        EquipmentLog          @relation(fields: [logId], references: [id], onDelete: Cascade)
  photos     EquipmentEntryPhoto[]

  @@map("equipment_log_entries")
  @@schema("equipment")
}

model EquipmentEntryPhoto {
  id        Int               @id @default(autoincrement())
  entryId   Int               @map("entry_id")
  fileName  String            @db.VarChar(255) @map("file_name")
  mimeType  String            @db.VarChar(50) @map("mime_type")
  fileData  String            @db.Text @map("file_data")
  fileSize  Int?              @map("file_size")
  createdAt DateTime          @default(now()) @map("created_at")
  entry     EquipmentLogEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@map("equipment_entry_photos")
  @@schema("equipment")
}

model VentReasonOption {
  id        Int      @id @default(autoincrement())
  label     String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("vent_reason_options")
  @@schema("equipment")
}

model CleaningTypeOption {
  id        Int      @id @default(autoincrement())
  label     String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("cleaning_type_options")
  @@schema("equipment")
}
